# Transit Permit Portal — Environment Configuration
# Architecture: Render (FastAPI backend) + Vercel (React frontend)
#
# ─── BACKEND (Render) ────────────────────────────────────────────────────────
# Copy relevant variables to your Render Dashboard → Environment section.

# PostgreSQL connection string (Supabase recommended)
# For local SQLite dev use: sqlite:///./transit_permits.db
DATABASE_URL=sqlite:///./transit_permits.db

# The Vercel frontend URL (used in QR codes & CORS)
FRONTEND_URL=http://localhost:5173

# Secret key for JWT Authentication (generate a strong random string)
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default Admin credentials (seeded into DB on first run if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Supabase Storage (for PDF uploads)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# ─── FRONTEND (Vercel) ───────────────────────────────────────────────────────
# Set these in your Vercel Dashboard → Project → Settings → Environment Variables.
# VITE_ prefix is required for Vite to expose vars to the browser.

# Your Render backend API URL
VITE_API_URL=https://your-render-app.onrender.com
